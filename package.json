{
  "name": "baekjoonhub",
  "version": "2.0.0",
  "description": "Chrome extension that automatically pushes your code to GitHub from competitive programming platforms",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "package": "npm run build && node build.mjs",
    "clean": "rimraf dist packages node_modules",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "prettier": "prettier --write \"**/*.@(cjs|mjs|js|ts|md|json|yml)\"",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "chrome-extension",
    "baekjoonhub",
    "competitive-programming",
    "github-integration",
    "typescript"
  ],
  "author": "flaxinger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BaekjoonHub/BaekjoonHub.git"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@eslint/js": "^9.33.0",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "terser": "^5.36.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "loglevel": "^1.9.2",
    "loglevel-plugin-prefix": "^0.8.4",
    "safe-template-parser": "^1.2.0"
  }
}
